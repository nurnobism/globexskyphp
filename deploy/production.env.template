# ================================================================
# GlobexSky — Production Environment Template
# ================================================================
# HOW TO USE:
#   1. Copy this file to .env in your project root:
#        cp deploy/production.env.template .env
#   2. Fill in every value marked with <FILL_IN>
#   3. NEVER commit .env to version control
# ================================================================

# ── Application ─────────────────────────────────────────────────
APP_NAME=GlobexSky
# Your live domain — no trailing slash
# Example: https://globexsky.com
APP_URL=<FILL_IN: https://yourdomain.com>
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=UTC

# ── Database ────────────────────────────────────────────────────
# Source: cPanel → MySQL Databases
# Host is almost always 'localhost' on Namecheap shared hosting
DB_HOST=localhost
DB_PORT=3306
# The database name you created in cPanel → MySQL Databases
# Note: Namecheap prefixes DB names with your cPanel username, e.g. user_globexsky
DB_NAME=<FILL_IN: cpanelusername_dbname>
# The DB user you created in cPanel → MySQL Databases
DB_USER=<FILL_IN: cpanelusername_dbuser>
# The password you set for that DB user
DB_PASS=<FILL_IN: strong_password_here>

# ── Session ─────────────────────────────────────────────────────
SESSION_LIFETIME=7200
SESSION_NAME=globexsky_session

# ── Admin Account ───────────────────────────────────────────────
# Used only on first run to seed the admin user
ADMIN_EMAIL=<FILL_IN: your_admin@yourdomain.com>
# IMPORTANT: Use a strong password (min 16 chars, mixed case, numbers, symbols)
# Avoid using $ in the password value as it may be misinterpreted by some shells
ADMIN_PASSWORD=<FILL_IN: ChangeMe_StrongPass123!>

# ── Email / SMTP ────────────────────────────────────────────────
# Source: cPanel → Email Accounts → Connect Devices
# Namecheap incoming/outgoing host is typically: mail.yourdomain.com
MAIL_HOST=<FILL_IN: mail.yourdomain.com>
# Use 587 (STARTTLS) or 465 (SSL) — 587 recommended
MAIL_PORT=587
# The full email address you created in cPanel → Email Accounts
MAIL_USERNAME=<FILL_IN: noreply@yourdomain.com>
# The password for that email account
MAIL_PASSWORD=<FILL_IN: email_account_password>
MAIL_ENCRYPTION=tls
MAIL_FROM_NAME=GlobexSky
MAIL_FROM_EMAIL=<FILL_IN: noreply@yourdomain.com>

# ── AI — DeepSeek ───────────────────────────────────────────────
# Source: https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=<FILL_IN: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx>
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MAX_TOKENS=2000
DEEPSEEK_TEMPERATURE=0.3
DEEPSEEK_TIMEOUT=30

# ── Stripe Payments ─────────────────────────────────────────────
# Source: https://dashboard.stripe.com → Developers → API Keys
# Use LIVE keys in production (pk_live_ / sk_live_)
STRIPE_PUBLISHABLE_KEY=<FILL_IN: pk_live_xxxxxxxxxxxxxxxxxxxx>
STRIPE_SECRET_KEY=<FILL_IN: sk_live_xxxxxxxxxxxxxxxxxxxx>
# Source: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=<FILL_IN: whsec_xxxxxxxxxxxxxxxxxxxx>

# ── KYC File Upload ─────────────────────────────────────────────
KYC_UPLOAD_DIR=uploads/kyc/
# 10 MB in bytes
KYC_MAX_FILE_SIZE=10485760

# ── Internationalisation ────────────────────────────────────────
DEFAULT_LANGUAGE=en
DEFAULT_CURRENCY=USD
# Source: https://www.exchangerate-api.com → Your API Keys
EXCHANGE_RATE_API_KEY=<FILL_IN: your_exchange_rate_api_key>
EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6/

# ── PWA ─────────────────────────────────────────────────────────
PWA_ENABLED=true

# ── Node.js Real-time Server ────────────────────────────────────
# Generate a strong random secret:  openssl rand -hex 32
JWT_SECRET=<FILL_IN: generate_with_openssl_rand_hex_32>
# Generate separately:               openssl rand -hex 32
INTERNAL_API_KEY=<FILL_IN: generate_with_openssl_rand_hex_32>
# Your live domain (no trailing slash)
# Example: https://globexsky.com
CORS_ORIGIN=<FILL_IN: https://yourdomain.com>
# Port for the Node.js server (must match Apache ProxyPass)
PORT=3001

# ── Google Analytics (optional) ─────────────────────────────────
# Source: Google Analytics → Admin → Property → Data Streams
# Example: G-XXXXXXXXXX
GOOGLE_ANALYTICS_ID=<FILL_IN_OPTIONAL: G-XXXXXXXXXX>
