# Apache configuration for GlobexSky
# Namecheap Shared Hosting (Apache + PHP)

Options -Indexes
ServerSignature Off

# PHP settings
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
    php_value max_execution_time 60
    php_value memory_limit 256M
    php_flag display_errors Off
</IfModule>

# URL Rewriting
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Redirect www to non-www (optional — uncomment if needed)
    # RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
    # RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

    # Force HTTPS (uncomment on live server)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Route all non-file, non-directory requests to index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php?_url=/$1 [QSA,L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Block access to sensitive files
<FilesMatch "\.(env|log|sql|sh|json|lock|md|gitignore)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to hidden files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protect config directory
<DirectoryMatch "config">
    Order allow,deny
    Deny from all
</DirectoryMatch>

# GZIP compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# Browser caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/jpeg "access plus 6 months"
    ExpiresByType image/png "access plus 6 months"
    ExpiresByType image/webp "access plus 6 months"
</IfModule>

# ============================================================
# Phase 11 — Security Hardening (appended)
# ============================================================

# Protect includes/ directory from direct browser access
<IfModule mod_rewrite.c>
    RewriteRule ^includes/ - [F,L]
</IfModule>

# Block access to additional sensitive file types not covered above
<FilesMatch "\.(git|gitignore|gitattributes|bak|orig|swp|dist|yml|yaml|conf|ini)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Prevent hotlinking of images from external sites
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_REFERER} !^$
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?%{HTTP_HOST} [NC]
    RewriteRule \.(jpe?g|png|gif|webp|svg|ico)$ - [F,NC,L]
</IfModule>

# Block common exploit patterns in query strings
<IfModule mod_rewrite.c>
    RewriteCond %{QUERY_STRING} (eval\(|base64_decode|python|perl|wget|curl) [NC]
    RewriteRule .* - [F,L]
    RewriteCond %{QUERY_STRING} (<|%3C).*script.*(>|%3E) [NC]
    RewriteRule .* - [F,L]
    RewriteCond %{QUERY_STRING} GLOBALS(=|\[|\%[0-9A-Z]{0,2}) [OR]
    RewriteCond %{QUERY_STRING} _REQUEST(=|\[|\%[0-9A-Z]{0,2})
    RewriteRule .* - [F,L]
</IfModule>

# Restrict HTTP methods — only allow GET, POST, HEAD
<LimitExcept GET POST HEAD>
    Order allow,deny
    Deny from all
</LimitExcept>

# Security headers via Apache (backup for PHP headers)
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>
