# GlobexSky Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME="Globex Sky"
APP_URL=https://globexsky.com
APP_ENV=production
APP_DEBUG=false

# Database (cPanel MySQL)
DB_HOST=localhost
DB_NAME=yourusername_globexsky
DB_USER=yourusername_dbuser
DB_PASS=your_strong_password

# Email (cPanel SMTP)
MAIL_HOST=mail.globexsky.com
MAIL_PORT=587
MAIL_USERNAME=noreply@globexsky.com
MAIL_PASSWORD=your_email_password
MAIL_ENCRYPTION=tls
MAIL_FROM_NAME="Globex Sky"
MAIL_FROM_EMAIL=noreply@globexsky.com

# DeepSeek AI (FREE — get key at platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-key-here

# Optional: Google Vision API for image search
GOOGLE_VISION_API_KEY=

# Optional: SMS Gateway
SMS_API_KEY=
SMS_FROM=GlobexSky

# Optional: Stripe
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# Optional: PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
