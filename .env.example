# GlobexSky Environment Configuration
# Copy this file to .env and fill in your values
# On Namecheap, set these in cPanel → PHP Environment Variables
# OR directly edit config/database.php and config/app.php

# Application
APP_NAME=GlobexSky
APP_URL=http://localhost:8080
APP_ENV=development
# Set to 'production' for live deployment
APP_DEBUG=true
# WARNING: Set to false in production
APP_TIMEZONE=UTC

# Database (from cPanel → MySQL Databases)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=globexsky
DB_USER=root
DB_PASS=

# Session
SESSION_LIFETIME=7200
SESSION_NAME=globexsky_session

# Admin Default
ADMIN_EMAIL=admin@globexsky.com
ADMIN_PASSWORD=
# IMPORTANT: Set a strong password before first run

# Email (Namecheap cPanel → Email Accounts)
MAIL_HOST=mail.yourdomain.com
MAIL_PORT=587
MAIL_USERNAME=noreply@yourdomain.com
MAIL_PASSWORD=your_email_password
MAIL_ENCRYPTION=tls
MAIL_FROM_NAME=GlobexSky
MAIL_FROM_EMAIL=noreply@globexsky.com

# AI (DeepSeek)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MAX_TOKENS=2000
DEEPSEEK_TEMPERATURE=0.3
DEEPSEEK_TIMEOUT=30

# Stripe Payment Gateway
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# KYC
KYC_UPLOAD_DIR=uploads/kyc/
KYC_MAX_FILE_SIZE=10485760

# i18n
DEFAULT_LANGUAGE=en
DEFAULT_CURRENCY=USD
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key_here
EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6/

# PWA
PWA_ENABLED=true
